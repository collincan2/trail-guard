{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Trail Guard Report Validation",
  "type": "object",

  "required": [
    "hazard_type",
    "severity_rating",
    "trail_segment",
    "reported_timestamp",
    "ai_description",
    "recommended_action"
  ],

  "optional": [
    "user_notes"
  ],

  "properties": {

    "hazard_type": {
      "type": "string",
      "enum": [
        "Park Infrastructure",
        "Debris",
        "Animal",
        "Fire Hazard",
        "Other"
      ]
    },

    "severity_rating": {
      "type": "integer",
      "minimum": 1,
      "maximum": 5
    },

    "trail_segment": {
      "type": "integer",
      "minimum": 1,
      "maximum": 7
    },

  "reported_timestamp": {
  "type": "string",
  "pattern": "^[0-9]{4}-(0[1-9]|1[0-2])-(0[1-9]|[12][0-9]|3[01]) ([01][0-9]|2[0-3]):[0-5][0-9]$"
    },

    "ai_description": {
      "type": "string",
      "minLength": 1
    },

    "recommended_action": {
      "type": "string",
      "minLength": 1
    },
    
    "user_notes":{
      "type": "string",
      "minLength": 1
    }

  }
}
